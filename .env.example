# Copy this to .env for local development
# On Railway, set these as environment variables in your project settings

# Required: Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Required: Fernet encryption key for stored API keys and passwords
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Database — leave blank to use SQLite locally, set for Railway PostgreSQL
# Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=

# Optional: Path to Google OAuth credentials JSON (only needed for Gmail OAuth reply detection)
GOOGLE_CLIENT_SECRETS_FILE=google_credentials.json

# Playwright — set to 0 on Railway so it uses the Nixpacks-installed Chromium
# Add this as an environment variable in Railway: PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_BROWSERS_PATH=0
